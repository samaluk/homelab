{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":disableRateLimiting",
    ":automergeBranch"
  ],
  "internalChecksFilter": "strict",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "additionalBranchPrefix": "{{parentDir}}-",
      "minimumReleaseAge": "3 days",
      "minimumReleaseAgeBehaviour": "timestamp-optional"
    },
    {
      "matchFileNames": [
        "immich/compose.yaml"
      ],
      "matchPackageNames": [
        "docker.io/valkey/valkey",
        "ghcr.io/immich-app/postgres"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "infisical/compose.yaml"
      ],
      "matchPackageNames": [
        "postgres"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "miniflux/compose.yaml"
      ],
      "matchPackageNames": [
        "postgres"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "qbittorrent/compose.yaml"
      ],
      "matchPackageNames": [
        "linuxserver/qbittorrent"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "immich/compose.yaml"
      ],
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning"
      ],
      "groupName": "immich app images"
    }
  ]
}
